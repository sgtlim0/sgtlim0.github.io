# =============================================================================
# H Chat Wiki — Environment Variables Reference
# =============================================================================
#
# This file lists ALL environment variables used across the monorepo.
# Copy to .env.local and fill in values for local development overrides.
#
# Environment-specific templates (safe to commit, no secrets):
#   .env.development  — Local development defaults (mock mode, localhost)
#   .env.production   — Production defaults (real mode, production URLs)
#   .env.test         — Test environment defaults (mock mode, test values)
#
# Override precedence (Next.js):
#   .env.local > .env.[mode].local > .env.[mode] > .env
#
# IMPORTANT: Never commit secrets (API keys, passwords, tokens).
#            Use .env.local or .env.*.local for secrets — they are gitignored.
# =============================================================================

# --- API Mode (mock | real) ---
# "mock" uses MSW handlers with mock data; "real" calls actual API endpoints.
NEXT_PUBLIC_API_MODE=mock

# --- API URLs ---
# Base URL for Next.js API routes
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# AI Core (FastAPI) URL — client-side
NEXT_PUBLIC_AI_CORE_URL=http://localhost:8000

# AI Core URL — server-side only (no NEXT_PUBLIC_ prefix, not exposed to browser)
AI_CORE_URL=http://localhost:8000

# --- Monitoring ---
# Sentry DSN (set in .env.local or CI — do NOT commit the actual DSN)
# NEXT_PUBLIC_SENTRY_DSN=

# App environment identifier for monitoring (development | staging | production)
NEXT_PUBLIC_APP_ENV=development

# Web Vitals reporting endpoint
# NEXT_PUBLIC_VITALS_ENDPOINT=

# --- Build ---
# Enable webpack bundle analyzer (true | false)
ANALYZE=false
