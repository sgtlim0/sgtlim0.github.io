{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_API_MODE",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_AI_CORE_URL",
    "NEXT_PUBLIC_APP_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "styles/**",
        "public/**",
        "content/**",
        "next.config.ts",
        "tsconfig.json",
        "package.json",
        "postcss.config.*"
      ],
      "outputs": ["out/**", ".next/**", "dist/**", "storybook-static/**"],
      "env": ["ANALYZE"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", "app/**", "eslint.config.*", ".eslintrc*"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "tsconfig.json", "tsconfig.*.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "__tests__/**", "vitest.config.*"],
      "outputs": ["coverage/**"]
    }
  }
}
