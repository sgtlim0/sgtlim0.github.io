{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "components/**", "lib/**", "styles/**", "*.ts", "*.tsx", "*.json", "*.css"],
      "outputs": ["out/**", ".next/**", "dist/**", "storybook-static/**"],
      "env": ["ANALYZE"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
