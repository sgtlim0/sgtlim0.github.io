{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["chrome", "node"],
    "paths": {
      "@hchat/ui": ["../../packages/ui/src"],
      "@hchat/ui/*": ["../../packages/ui/src/*"],
      "@hchat/tokens": ["../../packages/tokens"],
      "@hchat/tokens/*": ["../../packages/tokens/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
