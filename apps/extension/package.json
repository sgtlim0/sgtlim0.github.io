    "@types/chrome": "^0.1.39",
    "@types/node": "^20.19.39",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vitest": "^3.0.0"
  }
