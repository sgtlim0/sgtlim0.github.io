{
  "name": "hchat-wiki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:wiki": "npm run dev -w @hchat/wiki",
    "dev:hmg": "npm run dev -w @hchat/hmg",
    "dev:admin": "npm run dev -w @hchat/admin",
    "dev:user": "npm run dev -w @hchat/user",
    "dev:llm-router": "npm run dev -w @hchat/llm-router",
    "dev:desktop": "npm run dev -w @hchat/desktop",
    "dev:mobile": "npm run dev -w @hchat/mobile",
    "dev:storybook": "npm run dev -w @hchat/storybook",
    "build": "npx turbo run build",
    "build:wiki": "npm run build -w @hchat/wiki",
    "build:hmg": "npm run build -w @hchat/hmg",
    "build:admin": "npm run build -w @hchat/admin",
    "build:user": "npm run build -w @hchat/user",
    "build:llm-router": "npm run build -w @hchat/llm-router",
    "build:desktop": "npm run build -w @hchat/desktop",
    "build:mobile": "npm run build -w @hchat/mobile",
    "build:storybook": "npm run build -w @hchat/storybook",
    "lint": "npx turbo run lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:admin": "playwright test --project=admin",
    "test:e2e:hmg": "playwright test --project=hmg",
    "test:e2e:user": "playwright test --project=user",
    "test:e2e:llm-router": "playwright test --project=llm-router",
    "test:e2e:wiki": "playwright test --project=wiki",
    "test:e2e:cross": "playwright test tests/e2e/cross-app.spec.ts",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:cross-browser": "playwright test --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:e2e:error-paths": "playwright test tests/e2e/error-paths.spec.ts",
    "test:e2e:resilience": "playwright test tests/e2e/resilience.spec.ts",
    "analyze:admin": "ANALYZE=true npm run build:admin",
    "analyze:hmg": "ANALYZE=true npm run build:hmg",
    "analyze:user": "ANALYZE=true npm run build:user",
    "analyze:llm-router": "ANALYZE=true npm run build:llm-router",
    "analyze:desktop": "ANALYZE=true npm run build:desktop",
    "analyze:mobile": "ANALYZE=true npm run build:mobile",
    "lighthouse": "lhci autorun",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"apps/*/app/**/*.{ts,tsx}\" \"packages/*/src/**/*.{ts,tsx}\"",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker/docker-compose.prod.yml down",
    "db:seed": "docker compose exec postgres psql -U hchat -d hchat -f /seed/seed.sql",
    "test:load": "k6 run tests/load/k6-config.js",
    "test:load:staging": "k6 run -e BASE_URL=https://hchat-user.vercel.app -e WIKI_URL=https://sgtlim0.github.io -e ADMIN_URL=https://hchat-admin.vercel.app -e LLM_ROUTER_URL=https://hchat-llm-router.vercel.app tests/load/k6-config.js",
    "test:load:prod": "k6 run -e BASE_URL=https://hchat-user.vercel.app -e WIKI_URL=https://sgtlim0.github.io -e ADMIN_URL=https://hchat-admin.vercel.app -e LLM_ROUTER_URL=https://hchat-llm-router.vercel.app tests/load/k6-config.js",
    "check:bundle": "bash scripts/check-bundle-size.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "vitest": "^4.0.18"
  }
}
