{
  "name": "hchat-wiki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:wiki": "npm run dev -w @hchat/wiki",
    "dev:hmg": "npm run dev -w @hchat/hmg",
    "dev:admin": "npm run dev -w @hchat/admin",
    "dev:storybook": "npm run dev -w @hchat/storybook",
    "build": "npx turbo run build",
    "build:wiki": "npm run build -w @hchat/wiki",
    "build:hmg": "npm run build -w @hchat/hmg",
    "build:admin": "npm run build -w @hchat/admin",
    "build:storybook": "npm run build -w @hchat/storybook",
    "lint": "npx turbo run lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:admin": "playwright test --project=admin",
    "test:e2e:hmg": "playwright test --project=hmg"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "turbo": "^2"
  }
}
