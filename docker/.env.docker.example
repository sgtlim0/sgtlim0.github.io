# H Chat Docker 환경변수 (필수)
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요:
#   cp .env.docker.example .env

# [필수] 데이터베이스 비밀번호 (빈 값 불가)
DB_PASSWORD=change-me-to-a-strong-password

# [필수] JWT 서명 시크릿 (빈 값 불가, 최소 32자 권장)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# [선택] 데이터베이스 설정
DB_NAME=hchat
DB_USER=hchat

# [선택] LLM 설정
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
SEARCH_API_KEY=
